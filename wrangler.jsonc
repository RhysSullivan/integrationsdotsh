{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "integrationsdotsh",
  "compatibility_date": "2025-04-01",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "integrations.sh", "custom_domain": true },
    { "pattern": "www.integrations.sh", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  }
}
